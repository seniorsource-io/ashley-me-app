{
  "name": "ashley-me-app",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "turbo db:generate --filter=@repo/db",
    "db:migrate": "turbo db:migrate --filter=@repo/db",
    "db:push": "turbo db:push --filter=@repo/db",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio --config=packages/db/drizzle.config.ts",
    "scrape": "dotenv -e .env.local -- tsx scripts/carehome.ts"
  },
  "devDependencies": {
    "turbo": "^2",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.21.0"
  }
}
